{
  "name": "memorymesh",
  "version": "0.1.0",
  "description": "Local-first MCP memory server for Claude",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@qdrant/js-client-rest": "latest",
    "dotenv": "latest",
    "ollama": "latest",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "latest",
    "@types/node": "latest",
    "jest": "latest",
    "ts-jest": "latest",
    "ts-node": "latest",
    "typescript": "latest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/__tests__/**/*.test.ts"
    ]
  }
}
