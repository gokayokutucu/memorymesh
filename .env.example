TRANSPORT=http
HTTP_PORT=3456
# Host-run defaults (node on host):
QDRANT_HOST=localhost
QDRANT_PORT=6333
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
EMBEDDING_MODEL=nomic-embed-text
# Docker Compose bootstrap:
# - ollama-model-init service pulls EMBEDDING_MODEL on startup
# - first startup may take longer while the model is downloaded
# Host-run note:
# - if not using compose bootstrap, run: ollama pull ${EMBEDDING_MODEL}
MEMORYMESH_EMBED_CHUNK_MAX_CHARS=3500
QDRANT_COLLECTION=memories
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=memorymesh
MONGO_USER=memorymesh
MONGO_PASSWORD=memorymesh
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
MEMORYMESH_RETRIEVAL_MODE=preview
MEMORYMESH_PREVIEW_MAX_CHARS=500
MEMORYMESH_PREVIEW_MAX_LINES=12
MEMORYMESH_ADAPTIVE_THRESHOLD=800
MEMORYMESH_MAX_SAVE_PAYLOAD_BYTES=262144
MEMORYMESH_ENABLE_PROFILER_LOGS=false
MEMORYMESH_RETRY_MAX_ATTEMPTS=3
MEMORYMESH_RETRY_BASE_DELAY_MS=150
MEMORYMESH_RETRY_MAX_DELAY_MS=1500
MEMORYMESH_RETRY_JITTER_MS=50
MEMORYMESH_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
MEMORYMESH_CIRCUIT_BREAKER_OPEN_MS=10000
MEMORYMESH_EMBED_MAX_CONCURRENCY=2
MEMORYMESH_MEMORY_READ_ENABLED=true
MEMORYMESH_MEMORY_WRITE_ENABLED=true

# Docker Compose note:
# - memorymesh service loads this file via env_file: .env
# - compose also sets container connectivity hosts explicitly:
#   QDRANT_HOST=qdrant, OLLAMA_HOST=ollama, MONGO_HOST=mongodb, NEO4J_URI=bolt://neo4j:7687

# Example modes:
# Read-only:
# MEMORYMESH_MEMORY_READ_ENABLED=true
# MEMORYMESH_MEMORY_WRITE_ENABLED=false
#
# Read-write:
# MEMORYMESH_MEMORY_READ_ENABLED=true
# MEMORYMESH_MEMORY_WRITE_ENABLED=true
